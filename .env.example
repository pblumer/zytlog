# Local docker-compose overrides (development only)
# Copy to .env and adjust values if you do not use localhost.

# Frontend runtime endpoints used by Vite in docker-compose
DEV_VITE_API_BASE_URL=http://localhost:8000/api/v1
DEV_VITE_KEYCLOAK_URL=http://localhost:8080

# Backend JWT issuer expectation (must match token iss claim)
DEV_KEYCLOAK_ISSUER=http://localhost:8080/realms/zytlog

# Backend CORS allowlist (comma-separated)
DEV_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
