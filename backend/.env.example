# Backend
DATABASE_URL=postgresql+psycopg://zytlog:zytlog@localhost:5432/zytlog
APP_NAME=Zytlog API
API_V1_PREFIX=/api/v1

# Auth behavior
AUTH_ENABLED=true
AUTH_DISABLED_FALLBACK_USER_ID=1

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=zytlog
# Optional override values; if omitted they are derived from KEYCLOAK_URL + KEYCLOAK_REALM
# KEYCLOAK_ISSUER=http://localhost:8080/realms/zytlog
# KEYCLOAK_JWKS_URL=http://localhost:8080/realms/zytlog/protocol/openid-connect/certs
KEYCLOAK_VERIFY_AUDIENCE=false
KEYCLOAK_AUDIENCE=zytlog-api
